# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# downloaded ML models (fetched by `npm run setup` / predev / prebuild)
/public/models/

# local editor / Claude Code tooling config
/.claude/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# calibration harness artifacts (dev-time only)
calibration.db

# raw face dataset — NOT committed (privacy + bloat); see datasets/README.md to fetch
/datasets/face-skin-problems/train/
/datasets/face-skin-problems/valid/
/datasets/face-skin-problems/test/
